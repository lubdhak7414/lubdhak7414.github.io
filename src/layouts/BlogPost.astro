---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'

import BlogHero from '@/components/blog/Hero.astro'
import TOC from '@/components/blog/TOC.astro'
import BackButton from '@/components/BackButton.astro'
import AuthorBox from '@/components/AuthorBox.astro'

import { PERSON_ID, getCrawlerSafeOgImage } from '@/utils'
import { siteConfig } from '@/site-config'

import PageLayout from './BaseLayout.astro'

interface Props {
	post: CollectionEntry<'post'>
}

const { post } = Astro.props
const {
	data: { coverImage, description, ogImage, publishDate, title, updatedDate }
} = post

// `ogImage` (frontmatter) is an unprocessed string with unknown dimensions, so
// width/height are only emitted for the coverImage fallback we process here.
let socialImage: string | undefined = ogImage
let socialImageWidth: number | undefined
let socialImageHeight: number | undefined
if (!socialImage && coverImage) {
	// Crawler-safe JPEG (not WebP); see getCrawlerSafeOgImage.
	const card = await getCrawlerSafeOgImage(coverImage.src, 'jpeg')
	socialImage = card.src
	socialImageWidth = card.width
	socialImageHeight = card.height
}
const publishIso = publishDate.toISOString()
const modifiedIso =
	updatedDate && updatedDate.valueOf() !== publishDate.valueOf()
		? updatedDate.toISOString()
		: undefined
const { headings } = await render(post)

const postUrl = new URL(`/blog/${post.id}/`, Astro.site).toString()
const ogAbsolute = socialImage ? new URL(socialImage, Astro.site).toString() : undefined
// Reference the canonical Person entity (defined in full on the homepage + /about)
// by `@id` so Google consolidates the entity, but still inline `name`: the Person
// node isn't on this page, and Google requires `name` once an author object exists.
const authorRef = { '@id': PERSON_ID, name: siteConfig.author }
const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: publishIso,
	dateModified: modifiedIso ?? publishIso,
	...(ogAbsolute && { image: ogAbsolute }),
	author: authorRef,
	publisher: authorRef,
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': postUrl
	}
}
---

<PageLayout
	meta={{
		description,
		ogImage: socialImage,
		ogImageWidth: socialImageWidth,
		ogImageHeight: socialImageHeight,
		publishDate: publishIso,
		modifiedDate: modifiedIso,
		title
	}}
>
	<script type='application/ld+json' set:html={JSON.stringify(blogPostingSchema)} is:inline />
	<div class='w-full'>
		<BackButton href='/blog' />
		<div class='mt-8 gap-x-10 lg:flex lg:items-start'>
			{!!headings.length && <TOC headings={headings} />}
			<article class='flex-grow break-words'>
				<div id='blog-hero'><BlogHero content={post} /></div>
				<div
					class='prose prose-base prose-zinc text-muted-foreground dark:prose-invert prose-headings:font-medium prose-headings:text-foreground prose-headings:before:absolute prose-headings:before:-ms-4 prose-th:before:content-none mt-12'
				>
					<slot />
				</div>
				<AuthorBox />
			</article>
		</div>
		<button
			aria-label='Back to Top'
			class='bg-primary-foreground hover:border-border/75 fixed end-4 bottom-8 z-90 flex h-8 w-8 translate-y-28 items-center justify-center rounded-full border-2 border-transparent text-3xl opacity-0 transition-all duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12'
			data-show='false'
			id='to-top-btn'
			><svg
				aria-hidden='true'
				class='h-4 w-4'
				fill='none'
				focusable='false'
				stroke='currentColor'
				stroke-width='2'
				viewBox='0 0 24 24'
				xmlns='http://www.w3.org/2000/svg'
			>
				<path d='M4.5 15.75l7.5-7.5 7.5 7.5' stroke-linecap='round' stroke-linejoin='round'></path>
			</svg>
		</button>
	</div>
</PageLayout>

<script>
	const scrollBtn = document.getElementById('to-top-btn') as HTMLButtonElement
	const targetHeader = document.getElementById('blog-hero') as HTMLDivElement

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString()
		})
	}

	scrollBtn.addEventListener('click', () => {
		document.documentElement.scrollTo({ behavior: 'smooth', top: 0 })
	})

	const observer = new IntersectionObserver(callback)
	observer.observe(targetHeader)
</script>
