---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import { Image } from 'astro:assets'
import FormattedDate from '../FormattedDate.astro'
import TagIcon from '../TagIcon.astro'
import { slugifyTag } from '@/utils'
import { siteConfig } from '@/site-config'

interface Props {
	content: CollectionEntry<'post'>
}

const { content } = Astro.props
const { data } = content

const { remarkPluginFrontmatter } = await render(content)

const dateTimeOptions: Intl.DateTimeFormatOptions = {
	month: 'long'
}
---

{
	data.coverImage && (
		<div class='mb-6 aspect-video'>
			<Image
				alt={data.coverImage.alt}
				class='rounded-2xl object-cover'
				fetchpriority='high'
				loading='eager'
				src={data.coverImage.src}
				width={1656}
				height={1104}
			/>
		</div>
	)
}
{data.draft ? <span class='text-red-500'>(Draft)</span> : null}
<div class='flex flex-wrap items-center gap-x-3 gap-y-2'>
	<p class='text-xs'>
		By <a href='/about/' class='font-medium hover:underline'>{siteConfig.author}</a> /{' '}
		<FormattedDate date={data.publishDate} dateTimeOptions={dateTimeOptions} /> /{' '}
		{remarkPluginFrontmatter.minutesRead}
	</p>
</div>
<h1 class='mt-2 text-3xl font-medium sm:mb-1'>
	{data.title}
</h1>

{
	!!data.tags?.length && (
		<div class='mt-3 flex flex-row flex-wrap items-center gap-x-2 gap-y-1'>
			<TagIcon class='me-1 inline-block' />
			{data.tags.map((tag) => (
				<a
					aria-label={`View more blogs with the tag ${tag}`}
					class="inline-block before:content-['#'] hover:underline hover:underline-offset-4"
					href={`/tags/${slugifyTag(tag)}/`}
				>
					{tag}
				</a>
			))}
		</div>
	)
}

{
	data.updatedDate && data.updatedDate.valueOf() !== data.publishDate.valueOf() && (
		<p class='mt-6 text-base'>
			Last Updated:
			<FormattedDate class='ms-1' date={data.updatedDate} dateTimeOptions={dateTimeOptions} />
		</p>
	)
}
