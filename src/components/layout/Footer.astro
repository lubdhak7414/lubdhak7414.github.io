---
import { siteConfig } from '@/site-config'
---

<footer class='mx-auto mt-24 w-full'>
	<div class='border-border border-t pt-5' data-nosnippet>
		<div
			class='flex flex-col items-center gap-y-3 sm:flex sm:flex-row sm:items-center sm:justify-between sm:gap-y-0'
		>
			<div class='flex gap-x-4 text-sm'>
				<p>© {new Date().getFullYear()} {siteConfig.author}. All rights reserved.</p>
			</div>

			<div class='flex items-center justify-between'>
				<!-- Social Brands -->
				<div class='flex items-center gap-x-4'>
					<!-- Linkedin -->
					<a
						class='text-muted-foreground hover:text-foreground -m-2 inline-block p-2 transition-all'
						href={siteConfig.socials.linkedin}
						target='_blank'
						rel='noopener noreferrer'
						aria-label='Visit LinkedIn profile of Lubdhak'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 24 24'
							class='h-4 w-4'
							fill='none'
							stroke='currentColor'
							stroke-width='2'
							stroke-linecap='round'
							stroke-linejoin='round'
							aria-hidden='true'
							><path
								d='M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z'
							></path><rect width='4' height='12' x='2' y='9'></rect><circle cx='4' cy='4' r='2'
							></circle></svg
						>
					</a>

					<!-- Mail -->
					<a
						class='text-muted-foreground hover:text-foreground -m-2 inline-block p-2 transition-all'
						href={`mailto:${siteConfig.socials.email}`}
						aria-label='Mail to Safwan Usaid Lubdhak'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 24 24'
							class='h-4 w-4'
							fill='none'
							stroke='currentColor'
							stroke-width='2'
							stroke-linecap='round'
							stroke-linejoin='round'
							aria-hidden='true'
							><rect width='20' height='16' x='2' y='4' rx='2'></rect><path
								d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'></path></svg
						></a
					>

					<!-- Github -->
					<a
						class='text-muted-foreground hover:text-foreground -m-2 inline-block p-2 transition-all'
						href={siteConfig.socials.github}
						target='_blank'
						rel='noopener noreferrer'
						aria-label='Github profile of Safwan Usaid Lubdhak'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 24 24'
							class='h-4 w-4'
							fill='none'
							stroke='currentColor'
							stroke-width='2'
							stroke-linecap='round'
							stroke-linejoin='round'
							aria-hidden='true'
							><path
								d='M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4'
							></path><path d='M9 18c-4.51 2-5-2-7-2'></path></svg
						></a
					>
				</div>
			</div>
			<!-- End Social Brands -->
		</div>
	</div>
</footer>
