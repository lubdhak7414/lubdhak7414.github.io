---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/app.css'

import type { SiteMeta } from '@/types'
import { siteConfig } from '@/site-config'
import { getCrawlerSafeOgImage } from '@/utils'
import socialCard from '@/assets/social-card.png'

type Props = SiteMeta

const {
	description,
	ogImage,
	ogImageWidth,
	ogImageHeight,
	publishDate,
	modifiedDate,
	noIndex,
	title
} = Astro.props

const titleSeparator = '•'
const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`
const canonicalURL = new URL(Astro.url.pathname, Astro.site)

// The default card is emitted crawler-safe (PNG, not WebP); see getCrawlerSafeOgImage.
const defaultCard = ogImage ? null : await getCrawlerSafeOgImage(socialCard, 'png')
const socialImageURL = defaultCard
	? new URL(defaultCard.src, Astro.site).href
	: new URL(ogImage!, Astro.site).href
const ogWidth = defaultCard ? defaultCard.width : ogImageWidth
const ogHeight = defaultCard ? defaultCard.height : ogImageHeight
---

<meta charset='utf-8' />
<meta content='width=device-width, initial-scale=1.0, shrink-to-fit=no' name='viewport' />
<title>{siteTitle}</title>

<link rel='apple-touch-icon' sizes='180x180' href='/favicon/apple-touch-icon.png' />
<link rel='icon' type='image/png' sizes='32x32' href='/favicon/favicon-32x32.png' />
<link rel='icon' type='image/png' sizes='16x16' href='/favicon/favicon-16x16.png' />
<link rel='manifest' href='/favicon/site.webmanifest' />

{/* Preload the upright body font (woff2) to avoid FOUT; italic loads on demand
	(it's absent from most pages, so preloading it everywhere just steals
	bandwidth from the critical upright face during first paint). */}
<link rel='preload' href='/fonts/Satoshi-Variable.woff2' as='font' type='font/woff2' crossorigin />

{/* Robots */}
{noIndex && <meta content='noindex, nofollow' name='robots' />}

{/* Canonical URL */}
{!noIndex && <link rel='canonical' href={canonicalURL} />}

{/* Primary Meta Tags */}
<meta content={siteTitle} name='title' />
<meta content={description} name='description' />
<meta content={siteConfig.author} name='author' />

{/* Theme Colour */}
<meta content='#fcfdfe' name='theme-color' media='(prefers-color-scheme: light)' />
<meta content='#0a0a0b' name='theme-color' media='(prefers-color-scheme: dark)' />

{/* Open Graph / Facebook */}
<meta content={publishDate ? 'article' : 'website'} property='og:type' />
<meta content={title} property='og:title' />
<meta content={description} property='og:description' />
<meta content={canonicalURL} property='og:url' />
<meta content={siteConfig.title} property='og:site_name' />
<meta content={siteConfig.ogLocale} property='og:locale' />
<meta content={socialImageURL} property='og:image' />
{ogWidth && <meta content={String(ogWidth)} property='og:image:width' />}
{ogHeight && <meta content={String(ogHeight)} property='og:image:height' />}
{
	publishDate && (
		<>
			<meta content={siteConfig.author} property='article:author' />
			<meta content={publishDate} property='article:published_time' />
			{modifiedDate && <meta content={modifiedDate} property='article:modified_time' />}
		</>
	)
}

{/* Twitter */}
<meta content='summary_large_image' name='twitter:card' />
<meta content={canonicalURL} name='twitter:url' />
<meta content={title} name='twitter:title' />
<meta content={description} name='twitter:description' />
<meta content={socialImageURL} name='twitter:image' />

{/* Sitemap */}
<link href='/sitemap-index.xml' rel='sitemap' />

{/* RSS auto-discovery */}
<link href='/rss.xml' rel='alternate' title={siteConfig.title} type='application/rss+xml' />

<meta content='4b4b588afe303c5582bde3939866b70a' name='ocs-site-verification' />
{/* For opendesktop.org */}
