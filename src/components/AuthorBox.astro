---
import { siteConfig } from '@/site-config'
---

<aside
	class='border-border mt-16 flex flex-col gap-y-3 rounded-2xl border p-6 sm:flex-row sm:gap-x-5'
	aria-label='About the author'
>
	<div class='flex flex-col gap-y-2' data-nosnippet>
		<p class='text-muted-foreground text-xs tracking-wide uppercase'>About the author</p>
		<a href='/about/' class='text-foreground text-lg font-medium hover:underline'>
			{siteConfig.author}
		</a>
		<p class='text-muted-foreground text-sm leading-relaxed'>
			{siteConfig.bio}
		</p>
		<div class='mt-1 flex items-center gap-x-4 text-sm'>
			<a href='/about/' class='font-medium underline-offset-2 hover:underline'>About</a>
			<a
				href={siteConfig.socials.github}
				target='_blank'
				rel='noopener noreferrer'
				class='font-medium underline-offset-2 hover:underline'>GitHub</a
			>
			<a
				href={siteConfig.socials.linkedin}
				target='_blank'
				rel='noopener noreferrer'
				class='font-medium underline-offset-2 hover:underline'>LinkedIn</a
			>
		</div>
	</div>
</aside>
