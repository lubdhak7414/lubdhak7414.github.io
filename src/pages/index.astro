---
import PageLayout from '../layouts/BaseLayout.astro'
import Section from '../components/Section.astro'
import Card from '../components/Card.astro'
import ProjectCarousel from '../components/ProjectCarousel.astro'
import Label from '../components/Label.astro'
import SkillLayout from '../components/SkillLayout.astro'
import PostPreview from '@/components/blog/PostPreview.astro'

import { Image } from 'astro:assets'
import astro from '../assets/face.png'

import { getAllPosts, sortMDByDate } from '@/utils'

const languages = ['Python', 'Java', 'C++', 'Dart']
const frontend = ['JavaScript', 'HTML', 'CSS', 'React', 'Tailwind CSS', 'Bootstrap', 'Vue.js']
const backend = [
	'PHP',
	'MySQL',
	'Node.js',
	'Express.js',
	'MongoDB',
	'Django',
	'Laravel',
	'Java Spring Boot'
]
const others = ['Git', 'Linux', 'AWS', 'Nginx']
const technologies = ['WordPress', 'Astro', 'Next.js', 'Gatsby', 'GraphQL', 'Stripe', 'Firebase']

const MAX_POSTS = 10
const allPosts = await getAllPosts()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)
const projectPosts = allPosts
	.filter((p) => p.data.tags.includes('project'))
	.sort((a, b) => (a.data.homePageIdx ?? Infinity) - (b.data.homePageIdx ?? Infinity))
---

<PageLayout meta={{ title: 'Home' }}>
	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-7'>
			<Image
				src={astro}
				alt='profile'
				class='duration-800 h-28 w-auto rounded-full bg-gradient-to-r from-[#A2DFF7] via-[#E6D6B9] to-[#FF6F61] p-2 transition-all ease-in-out'
				loading='eager'
			/>

			<div class='flex flex-col items-center gap-y-4'>
				<h1 class='text-3xl font-bold'>Safwan Usaid Lubdhak</h1>
				<div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
					<Label title='Freelancer'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'
							><rect width='20' height='14' x='2' y='7' rx='2' ry='2' /><path d='M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16' /></svg
						>
					</Label>
					<Label title='Bangladesh'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'
							><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z' /><circle cx='12' cy='10' r='3' /></svg
						>
					</Label>
					<Label title='Mail me' as='a' href='mailto:hello@saf1.me' target='_blank'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'
							><rect width='20' height='16' x='2' y='4' rx='2' /><path d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7' /></svg
						>
					</Label>
				</div>
			</div>
		</section>

		<Section title='About'>
			<p class='text-muted-foreground'>
				Safwan Usaid Lubdhak is a software developer based in Bangladesh. He, which is to say, I,
				have a few years of experience in web development and have worked with a wide range of
				technologies. I love to talk about nerd stuff, too, so hit me up if you're into it.
			</p>
		</Section>

		{
			projectPosts.length > 0 && (
				<Section title='Projects'>
					<ProjectCarousel>
						{projectPosts.map((post) => (
							<a
								href={`/blog/${post.id}/`}
								class='w-[85%] flex-shrink-0 sm:w-[calc(50%-0.5rem)]'
							>
								<div class='flex h-full flex-col rounded-2xl border border-border bg-primary-foreground transition-all hover:border-foreground/25 hover:shadow-xs'>
									{post.data.coverImage && (
										<Image
											src={post.data.coverImage.src}
											alt={post.data.coverImage.alt}
											class='h-48 w-full rounded-t-2xl object-cover'
											loading='lazy'
										/>
									)}
									<div class='flex flex-grow flex-col gap-y-0.5 px-5 py-4'>
										<h3 class='text-lg font-medium'>{post.data.title}</h3>
										<p class='line-clamp-2 text-muted-foreground'>{post.data.description}</p>
									</div>
								</div>
							</a>
						))}
					</ProjectCarousel>
				</Section>
			)
		}

		<Section title='Experience'>
			<Card
				heading='Website Developer'
				subheading='Freelanced for Various Clients'
				date='2019 - Present'
				imagePath='/src/assets/web_logo.png'
				altText='Web Development and Design'
				imageClass='h-12 w-auto md:-left-16'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>
						Designed and developed responsive WordPress sites (for rapid deployment) with a focus on
						user experience and conversion optimization.
					</li>
					<li>
						Led redesigns, improving site functionality and navigation for enhanced user engagement.
					</li>
				</ul>
			</Card>
		</Section>

		<Section title='Education'>
			<Card
				heading='Brac University'
				subheading='BSc. in Computer Science and Engineering'
				date='Fall 2022 - Spring 2026'
				imagePath='/src/assets/edu_logo.png'
				altText='Brac University'
				imageClass='h-12 w-auto md:-left-16'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					<li>
						Completed core courses including Programming Language I and II, Data Structures,
						Algorithms, Discrete Mathematics, Digital Logic Design, and Data Communications.
					</li>
				</ul>
			</Card>
		</Section>

		{
			allPostsByDate.length > 0 && (
				<Section title='Posts'>
					<ul class='flex flex-col gap-y-2'>
						{allPostsByDate.map((p) => (
							<li class='flex flex-col gap-x-2 sm:flex-row'>
								<PostPreview post={p} />
							</li>
						))}
					</ul>
				</Section>
			)
		}

		<Section title='Skills'>
			<SkillLayout title='Languages' skills={languages} />
			<SkillLayout title='Frontend' skills={frontend} />
			<SkillLayout title='Backend' skills={backend} />
			<SkillLayout title='Technologies' skills={technologies} />
			<SkillLayout title='Others' skills={others} />
		</Section>
	</div>

</PageLayout>
