---
import PageLayout from '@/layouts/BaseLayout.astro'
import ToolSection from '@/components/ToolSection.astro'
import BackButton from '@/components/BackButton.astro'

const PRODUCTIVITY = [
	{
		name: 'Zen',
		description: 'Browser',
		href: 'https://zen-browser.app/',
		iconPath: 'zen-blue'
	},
	{
		name: 'Obsidian',
		description: 'Note Taking',
		href: 'https://obsidian.md/',
		iconPath: 'obsidian'
	},
	{
		name: 'Activity Watch',
		description: 'Activity Tracker',
		href: 'https://activitywatch.net/',
		iconPath: 'activitywatch'
	},

	{
		name: 'OBS Studio',
		description: 'Screen Capturer',
		href: 'https://obsproject.com/',
		iconPath: 'obs'
	},
	{
		name: 'Excalidraw',
		description: 'Diagrams',
		href: 'https://excalidraw.com/',
		iconPath: 'excalidraw'
	}
]

const DEVELOPMENT = [
	{
		name: 'VS Code',
		description: 'IDE',
		href: 'https://code.visualstudio.com/',
		iconPath: 'vs_code'
	},
	{
		name: 'Pi',
		description: 'Coding Agent',
		href: 'https://pi.dev/',
		iconPath: 'pi-coding-agent'
	},
	{
		name: 'ChatGPT',
		description: 'AI',
		href: 'https://chat.openai.com/',
		iconPath: 'chatgpt'
	},
	{
		name: 'Claude',
		description: 'AI',
		href: 'https://claude.ai/',
		iconPath: 'claude'
	},
	{
		name: 'GitHub Desktop',
		description: 'Git Client',
		href: 'https://desktop.github.com/',
		iconPath: 'github'
	},
	{
		name: 'Docker',
		description: 'Containerization',
		href: 'https://www.docker.com/',
		iconPath: 'docker'
	},
	{
		name: 'Hoppscotch',
		description: 'API Testing',
		href: 'https://hoppscotch.com/',
		iconPath: 'hoppscotch'
	},
	{
		name: 'Kitty',
		description: 'Terminal',
		href: 'https://sw.kovidgoyal.net/kitty/',
		iconPath: 'kitty'
	},
	{
		name: 'Bash',
		description: 'Shell',
		href: 'https://www.gnu.org/software/bash/',
		iconPath: 'bash'
	},
	{
		name: 'Cloudflare',
		description: 'Deploy & DNS',
		href: 'https://www.cloudflare.com/',
		iconPath: 'cloudflare'
	},
	{
		name: 'Ollama',
		description: 'Local AI',
		href: 'https://ollama.com/',
		iconPath: 'ollama'
	}
]
---

<PageLayout meta={{ title: 'Tools', description: 'Tools and software I use daily' }}>
	<div class='w-full'>
		<BackButton href='/' />

		<div class='mt-5 flex w-full flex-col gap-y-10'>
			<div>
				<h1 class='mb-1 text-2xl font-bold'>Tools</h1>
				<p>Tools and software I use daily</p>
			</div>

			<ToolSection title='Productivity' tools={PRODUCTIVITY} />
			<ToolSection title='Development' tools={DEVELOPMENT} />
		</div>
	</div>
</PageLayout>
