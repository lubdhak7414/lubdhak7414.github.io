---
import PageLayout from '@/layouts/BaseLayout.astro'
import Button from '@/components/Button.astro'
import { jsonLdScript } from '@/utils'
import { excuses } from '../data/excuses'

const meta = {
	description: 'Page not found',
	title: '404',
	noIndex: true
}
---

<PageLayout meta={meta}>
	<section class='relative flex min-h-[70vh] flex-col items-center justify-center px-4 text-center'>
		{/* dramatic glow behind the number */}
		<div
			aria-hidden='true'
			class='glow pointer-events-none absolute top-1/3 left-1/2 -z-10 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-r from-indigo-500/30 via-purple-500/30 to-pink-500/30 blur-3xl'
		>
		</div>

		<h1
			class='glitch animate-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text font-extrabold text-transparent'
			data-text='404'
		>
			404
		</h1>

		<p class='text-foreground mt-2 text-2xl font-semibold sm:text-3xl'>
			This page pulled a disappearing act.
		</p>

		{/* terminal-style excuse generator */}
		<div
			class='border-border bg-primary-foreground mt-8 w-full max-w-xl overflow-hidden rounded-xl border text-left shadow-sm'
		>
			<div class='border-border flex items-center gap-2 border-b px-4 py-2.5'>
				<span class='h-3 w-3 rounded-full bg-[#ff5f57]'></span>
				<span class='h-3 w-3 rounded-full bg-[#febc2e]'></span>
				<span class='h-3 w-3 rounded-full bg-[#28c840]'></span>
				<span class='text-muted-foreground ml-2 font-mono text-xs'>bash - why-this-happened</span>
			</div>
			<div class='px-4 py-4 font-mono text-sm leading-relaxed sm:text-base'>
				<p class='text-muted-foreground'>
					<span class='text-emerald-500'>$</span> git blame this-page
				</p>
				<p id='excuse' aria-live='polite' class='text-foreground mt-2 min-h-[2.5em]'>
					{excuses[0]}
				</p>
			</div>
		</div>

		<div class='mt-7 flex flex-wrap items-center justify-center gap-3'>
			<button
				id='roll-excuse'
				type='button'
				class='border-border bg-primary-foreground hover:bg-input inline-flex items-center gap-x-1.5 rounded-lg border px-3 py-1.5 text-sm transition-all'
			>
				<span aria-hidden='true'>🎲</span> Roll another excuse
			</button>

			<Button title='Take me home' href='/' style='button'>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					width='14'
					height='14'
					viewBox='0 0 24 24'
					slot='icon-after'
					aria-hidden='true'
					class='-scale-x-100'
				>
					<path
						fill='currentColor'
						d='m6.921 12.5l5.792 5.792L12 19l-7-7l7-7l.713.708L6.921 11.5H19v1z'></path>
				</svg>
			</Button>
		</div>

		<p class='text-muted-foreground mt-4 text-sm'>
			…or go read the <a href='/blog/' class='text-foreground underline underline-offset-4'>blog</a> instead.
		</p>
	</section>

	<style>
		.glitch {
			position: relative;
			display: inline-block;
			font-size: clamp(6rem, 24vw, 13rem);
			line-height: 0.9;
			letter-spacing: -0.03em;
		}
		.glitch::before,
		.glitch::after {
			content: attr(data-text);
			position: absolute;
			inset: 0;
			z-index: -1;
			pointer-events: none;
		}
		.glitch::before {
			color: #22d3ee;
			animation: glitch-a 2.4s infinite steps(2, end) alternate;
		}
		.glitch::after {
			color: #fb7185;
			animation: glitch-b 1.9s infinite steps(2, end) alternate;
		}

		@keyframes glitch-a {
			0%,
			100% {
				transform: translate(-2px, 0);
				clip-path: inset(0 0 0 0);
			}
			20% {
				transform: translate(-5px, 1px);
				clip-path: inset(18% 0 52% 0);
			}
			40% {
				transform: translate(3px, -1px);
				clip-path: inset(58% 0 12% 0);
			}
			60% {
				transform: translate(-4px, 1px);
				clip-path: inset(40% 0 35% 0);
			}
			80% {
				transform: translate(2px, 0);
				clip-path: inset(8% 0 70% 0);
			}
		}
		@keyframes glitch-b {
			0%,
			100% {
				transform: translate(2px, 0);
				clip-path: inset(0 0 0 0);
			}
			25% {
				transform: translate(5px, -1px);
				clip-path: inset(50% 0 20% 0);
			}
			50% {
				transform: translate(-3px, 1px);
				clip-path: inset(15% 0 60% 0);
			}
			75% {
				transform: translate(4px, -1px);
				clip-path: inset(70% 0 8% 0);
			}
		}

		.glow {
			animation: glow-pulse 4s ease-in-out infinite;
		}
		@keyframes glow-pulse {
			0%,
			100% {
				opacity: 0.7;
				transform: translate(-50%, -50%) scale(1);
			}
			50% {
				opacity: 1;
				transform: translate(-50%, -50%) scale(1.12);
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.glitch::before,
			.glitch::after {
				animation: none;
				opacity: 0;
			}
			.glow {
				animation: none;
			}
		}
	</style>

	<script is:inline type='application/json' id='excuses-data' set:html={jsonLdScript(excuses)} />

	<script is:inline>
		const dataEl = document.getElementById('excuses-data')
		const excuses = dataEl ? JSON.parse(dataEl.textContent) : []

		const excuseEl = document.getElementById('excuse')
		const rollBtn = document.getElementById('roll-excuse')
		let current = 0

		function roll() {
			if (!excuseEl) return
			let next = current
			while (next === current && excuses.length > 1) {
				next = Math.floor(Math.random() * excuses.length)
			}
			current = next
			excuseEl.textContent = excuses[next]
		}

		rollBtn?.addEventListener('click', roll)
		roll()
	</script>
</PageLayout>
