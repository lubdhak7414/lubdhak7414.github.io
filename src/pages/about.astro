---
import PageLayout from '../layouts/BaseLayout.astro'
import { Image } from 'astro:assets'
import face from '../assets/face.png'
import { personSchema } from '@/utils'
import { siteConfig } from '@/site-config'

const aboutDescription =
	'About Safwan Usaid Lubdhak - CS graduate from Bangladesh working on web apps, DevOps, and AI systems.'

// AboutPage wrapper pointing at the canonical Person entity (shared `@id`).
const aboutPageSchema = {
	'@context': 'https://schema.org',
	'@type': 'AboutPage',
	url: `${siteConfig.url}/about/`,
	mainEntity: { '@id': personSchema['@id'] }
}
---

<PageLayout meta={{ title: 'About', description: aboutDescription }}>
	<script type='application/ld+json' set:html={JSON.stringify(personSchema)} is:inline />
	<script type='application/ld+json' set:html={JSON.stringify(aboutPageSchema)} is:inline />

	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-6 text-center'>
			<Image
				src={face}
				alt='Safwan Usaid Lubdhak'
				class='h-28 w-auto rounded-full bg-gradient-to-r from-[#A2DFF7] via-[#E6D6B9] to-[#FF6F61] p-2'
				loading='eager'
			/>
			<div class='flex flex-col items-center gap-y-3'>
				<h1 class='text-3xl font-bold'>About Safwan Usaid Lubdhak</h1>
				<p class='text-muted-foreground max-w-prose'>
					CS graduate from Bangladesh. Web apps, DevOps, AI, and the occasional Linux tool.
				</p>
			</div>
		</section>

		<section class='prose prose-base prose-zinc dark:prose-invert text-muted-foreground max-w-none'>
			<h2>What I do</h2>
			<p>
				I'm Safwan - CS graduate from Bangladesh. I work on web applications, DevOps and cloud
				infrastructure, and AI systems. I also build open-source Linux tools - things like a
				circular Alt+Tab switcher for KDE Plasma and a self-hosted search setup.
			</p>

			<h2>Open source</h2>
			<p>
				Most of my projects are public. I write about what I'm working on in the blog here, and the
				source is on
				<a href={siteConfig.socials.github} target='_blank' rel='noopener noreferrer'>GitHub</a>.
			</p>

			<h2>Elsewhere &amp; contact</h2>
			<ul>
				<li>
					GitHub:
					<a href={siteConfig.socials.github} target='_blank' rel='noopener noreferrer'
						>github.com/lubdhak7414</a
					>
				</li>
				<li>
					LinkedIn:
					<a href={siteConfig.socials.linkedin} target='_blank' rel='noopener noreferrer'
						>linkedin.com/in/lubdhak7414</a
					>
				</li>
				<li>
					Email: <a href={`mailto:${siteConfig.socials.email}`}>{siteConfig.socials.email}</a>
				</li>
			</ul>

			<p>
				Want to see what I've built? Read the <a href='/blog/'>blog</a> for project write-ups, or head
				back to the <a href='/'>homepage</a> for the full résumé.
			</p>
		</section>
	</div>
</PageLayout>
