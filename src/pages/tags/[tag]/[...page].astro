---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import Pagination from '@/components/Paginator.astro'
import PostPreview from '@/components/blog/PostPreview.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import BackButton from '@/components/BackButton.astro'
import { getAllPosts, getUniqueTags, slugifyTag, sortMDByDate, jsonLdScript } from '@/utils'
import { siteConfig } from '@/site-config'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const allPosts = await getAllPosts()
	const allPostsByDate = sortMDByDate(allPosts)
	const uniqueTags = getUniqueTags(allPostsByDate)

	// Fail loudly if two distinct tags slugify to the same value - otherwise
	// `paginate` would emit duplicate static paths and the build crashes with an
	// opaque error. A named tag pair is far easier to act on.
	const slugOwner = new Map<string, string>()
	for (const tag of uniqueTags) {
		const slug = slugifyTag(tag)
		const owner = slugOwner.get(slug)
		if (owner && owner !== tag) {
			throw new Error(
				`Tag slug collision: "${owner}" and "${tag}" both slugify to "${slug}". Rename one tag.`
			)
		}
		slugOwner.set(slug, tag)
	}

	return uniqueTags.flatMap((tag) => {
		const filterPosts = allPostsByDate.filter((post) => post.data.tags.includes(tag))
		return paginate(filterPosts, {
			pageSize: 10,
			// URL uses the slug; the human-readable tag is passed through props.
			params: { tag: slugifyTag(tag) },
			props: { tag }
		})
	})
}

interface Props {
	page: Page<CollectionEntry<'post'>>
	tag: string
}

const { page, tag } = Astro.props

const meta = {
	description: `Articles and project write-ups tagged ${tag} by ${siteConfig.author}.`,
	title: `Tag: ${tag}`
}

const tagUrl = new URL(`/tags/${Astro.params.tag}/`, Astro.site).toString()
const collectionPageSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: `Posts tagged #${tag}`,
	url: tagUrl,
	description: `Articles and project write-ups tagged ${tag} by ${siteConfig.author}.`
}

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: `← Previous Posts`,
			url: page.url.prev
		}
	}),
	...(page.url.next && {
		nextUrl: {
			text: `Next Posts →`,
			url: page.url.next
		}
	})
}
---

<PageLayout meta={meta}>
	<script type='application/ld+json' set:html={jsonLdScript(collectionPageSchema)} is:inline />
	<div class='w-full'>
		<BackButton href='/blog' />
		<h1 class='mt-5 mb-6 flex items-end gap-x-2 text-2xl font-bold'>
			Tags:
			<span class='text-xl'>#{tag}</span>
		</h1>
		<section aria-label='Blog post list'>
			<ul class='flex flex-col gap-y-3 text-start'>
				{page.data.map((p) => <PostPreview as='h2' post={p} withDesc />)}
			</ul>
			<Pagination {...paginationProps} />
		</section>
	</div>
</PageLayout>
